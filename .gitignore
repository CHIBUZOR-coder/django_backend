# ===========================
# Python
# ===========================
__pycache__/
*.py[cod]          # .pyc, .pyo, .pyd compiled files
*.pyo
*.pyd
*.so               # C extensions

# ===========================
# Virtual Environment
# ===========================
env/
venv/
.venv/
ENV/

# ===========================
# Environment Variables (MOST IMPORTANT)
# ===========================
.env
.env.*             # covers .env.local, .env.production, etc.
*.env

# ===========================
# Django Specific
# ===========================
*.log              # Django log files
local_settings.py  # local overrides of settings.py
db.sqlite3         # local dev database
db.sqlite3-journal
media/             # user-uploaded files (use Cloudinary/S3 in prod)

# ===========================
# Static Files
# ===========================
/staticfiles/      # collected static files (generated by collectstatic)
/static/           # only if auto-generated; keep if you manually add files here

# ===========================
# Migrations (debatable — see note below)
# ===========================
# */migrations/    # most teams DO commit migrations, so leave this commented

# ===========================
# Testing & Coverage
# ===========================
.coverage
htmlcov/
.pytest_cache/
coverage.xml

# ===========================
# IDE & Editor
# ===========================
.vscode/
.idea/
*.swp
*.swo
.DS_Store          # macOS
Thumbs.db          # Windows

# ===========================
# Secrets / Keys
# ===========================
*.pem
*.key
secrets.json